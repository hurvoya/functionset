def check_outliers_iqr(df, table_name, numeric_cols, country_col="country"):
    """
    Détecte les outliers avec la méthode IQR.
    Ce n'est pas forcément une erreur, plutôt un signal à analyser.
    """

    results = []

    for country, subdf in df.groupby(country_col):
        for col in numeric_cols:
            q1 = subdf[col].quantile(0.25)
            q3 = subdf[col].quantile(0.75)
            iqr = q3 - q1

            lower_bound = q1 - 1.5 * iqr
            upper_bound = q3 + 1.5 * iqr

            outlier_count = (
                (subdf[col] < lower_bound) |
                (subdf[col] > upper_bound)
            ).sum()

            results.append({
                "table": table_name,
                "country": country,
                "check": "outliers_iqr",
                "column": col,
                "lower_bound": lower_bound,
                "upper_bound": upper_bound,
                "outlier_count": outlier_count,
                "status": "WARNING" if outlier_count > 0 else "OK"
            })

    return pd.DataFrame(results)

def check_numeric_quality(
    df,
    table_name,
    numeric_cols,
    country_col="country",
    allow_negative=True
):
    """
    Contrôle les colonnes numériques :
    - valeurs manquantes
    - min
    - max
    - moyenne
    - nombre de valeurs négatives
    - nombre de zéros
    """

    results = []

    for country, subdf in df.groupby(country_col):
        for col in numeric_cols:
            negative_count = (subdf[col] < 0).sum() if not allow_negative else np.nan
            zero_count = (subdf[col] == 0).sum()

            results.append({
                "table": table_name,
                "country": country,
                "check": "numeric_quality",
                "column": col,
                "missing_rate": round(subdf[col].isna().mean(), 4),
                "min": subdf[col].min(),
                "max": subdf[col].max(),
                "mean": subdf[col].mean(),
                "zero_count": zero_count,
                "negative_count": negative_count,
                "status": "KO" if not allow_negative and negative_count > 0 else "OK"
            })

    return pd.DataFrame(results)

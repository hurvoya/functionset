def check_categorical_quality(
    df,
    table_name,
    categorical_cols,
    country_col="country",
    max_categories=50
):
    """
    Contrôle les colonnes catégorielles :
    - nombre de catégories distinctes
    - catégories les plus fréquentes
    - catégories potentiellement trop nombreuses
    """

    results = []

    for country, subdf in df.groupby(country_col):
        for col in categorical_cols:
            nunique = subdf[col].nunique(dropna=True)
            top_values = (
                subdf[col]
                .value_counts(dropna=False)
                .head(5)
                .to_dict()
            )

            results.append({
                "table": table_name,
                "country": country,
                "check": "categorical_quality",
                "column": col,
                "n_unique": nunique,
                "top_values": top_values,
                "threshold": max_categories,
                "status": "OK" if nunique <= max_categories else "WARNING"
            })

    return pd.DataFrame(results)

def check_duplicates(df, table_name, key_cols, country_col="country"):
    """
    Vérifie les doublons sur une clé métier.
    Exemple de clé : ["country", "customer_id"]
    """

    results = []

    if country_col in key_cols:
        group_col = country_col
    else:
        group_col = country_col

    for country, subdf in df.groupby(group_col):
        duplicate_count = subdf.duplicated(subset=key_cols).sum()

        results.append({
            "table": table_name,
            "country": country,
            "check": "duplicate_keys",
            "column": "+".join(key_cols),
            "value": duplicate_count,
            "threshold": 0,
            "status": "OK" if duplicate_count == 0 else "KO"
        })

    return pd.DataFrame(results)

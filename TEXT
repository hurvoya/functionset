import pandas as pd
import numpy as np

# Sécurité sur les dates
closed["creation date"] = pd.to_datetime(closed["creation date"], errors="coerce")
closed["end date"] = pd.to_datetime(closed["end date"], errors="coerce")

# Sécurité sur le temps
closed["time_minutes_task"] = pd.to_numeric(
    closed["time_minutes_task"],
    errors="coerce"
)

# Filtrer à partir de janvier 2026 sur la creation date
closed_2026 = closed[
    closed["creation date"] >= pd.Timestamp("2026-01-01")
].copy()

# Créer le mois de clôture
closed_2026["closing_month"] = closed_2026["end date"].dt.to_period("M").dt.to_timestamp()

# Agréger les minutes par pays et mois de clôture
df_monthly_workload = (
    closed_2026
    .groupby(["country", "closing_month"], as_index=False)
    .agg(
        total_minutes=("time_minutes_task", "sum"),
        nb_tasks=("case id", "count")
    )
)

# Conversion minutes -> heures
df_monthly_workload["total_hours"] = df_monthly_workload["total_minutes"] / 60

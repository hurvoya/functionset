def check_volume_by_country(df, table_name, country_col="country"):
    """
    Vérifie le nombre de lignes par pays.
    """

    result = (
        df.groupby(country_col)
        .size()
        .reset_index(name="row_count")
    )

    result["table"] = table_name
    result["check"] = "volume_by_country"

    return result[["table", country_col, "check", "row_count"]]

# Conversion des dates en datetime, puis suppression de la timezone
closed["creation date"] = (
    pd.to_datetime(closed["creation date"], errors="coerce", utc=True)
    .dt.tz_localize(None)
)

closed["end date"] = (
    pd.to_datetime(closed["end date"], errors="coerce", utc=True)
    .dt.tz_localize(None)
)

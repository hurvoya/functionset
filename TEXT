def check_date_quality(
    df,
    table_name,
    date_cols,
    country_col="country",
    allow_future_dates=False
):
    """
    Contrôle les colonnes de date :
    - taux de valeurs manquantes
    - date min
    - date max
    - nombre de dates futures
    """

    results = []
    today = pd.Timestamp.today().normalize()

    for country, subdf in df.groupby(country_col):
        for col in date_cols:
            date_series = pd.to_datetime(subdf[col], errors="coerce")

            future_count = (date_series > today).sum()

            results.append({
                "table": table_name,
                "country": country,
                "check": "date_quality",
                "column": col,
                "missing_rate": round(date_series.isna().mean(), 4),
                "min_date": date_series.min(),
                "max_date": date_series.max(),
                "future_date_count": future_count,
                "status": "KO" if not allow_future_dates and future_count > 0 else "OK"
            })

    return pd.DataFrame(results)

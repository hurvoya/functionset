def check_missing_values(df, table_name, country_col="country", threshold=0.05):
    """
    Calcule le taux de valeurs manquantes par colonne et par pays.
    """

    results = []

    for country, subdf in df.groupby(country_col):
        for col in subdf.columns:
            missing_rate = subdf[col].isna().mean()

            results.append({
                "table": table_name,
                "country": country,
                "check": "missing_rate",
                "column": col,
                "value": round(missing_rate, 4),
                "threshold": threshold,
                "status": "OK" if missing_rate <= threshold else "KO"
            })

    return pd.DataFrame(results)
